# Focusa Environment Configuration
# Copy to .env and customize.

# ── Daemon ────────────────────────────────────────────────

# Data directory (default: ~/.focusa)
# FOCUSA_DATA_DIR=~/.focusa

# API bind address (default: 127.0.0.1:8787)
# Local only (safe default):
# FOCUSA_BIND=127.0.0.1:8787
# Allow all interfaces (for remote access via Tailscale):
# FOCUSA_BIND=0.0.0.0:8787
# Bind to Tailscale IP only:
# FOCUSA_BIND=100.94.238.56:8787

# Log level
# RUST_LOG=focusa=info

# ── Proxy Adapter ────────────────────────────────────────

# Upstream LLM API (default: OpenAI)
# FOCUSA_UPSTREAM_URL=https://api.openai.com/v1/chat/completions
# FOCUSA_API_KEY=sk-...

# ── Tuning ───────────────────────────────────────────────

# Max prompt tokens (default: 6000)
# FOCUSA_MAX_PROMPT_TOKENS=6000

# Reserve for response (default: 2000)
# FOCUSA_RESERVE_FOR_RESPONSE=2000

# ECS externalize threshold (bytes, default: 8192)
# FOCUSA_ECS_THRESHOLD_BYTES=8192

# Focus Gate surface threshold (default: 2.2)
# FOCUSA_GATE_SURFACE_THRESHOLD=2.2

# ── CLI ──────────────────────────────────────────────────

# Override API URL for CLI (default: http://127.0.0.1:8787)
# FOCUSA_API_URL=http://100.94.238.56:8787

# ── TUI ──────────────────────────────────────────────────

# Override API URL for TUI (same env var as CLI)
# FOCUSA_API_URL=http://100.94.238.56:8787
