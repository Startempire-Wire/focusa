# Focusa Environment Configuration
# Copy to .env and customize.

# Data directory (default: ~/.focusa)
# FOCUSA_DATA_DIR=~/.focusa

# API bind address (default: 127.0.0.1:8787)
# FOCUSA_API_BIND=127.0.0.1:8787

# Log level
# RUST_LOG=focusa=info

# Max prompt tokens (default: 6000)
# FOCUSA_MAX_PROMPT_TOKENS=6000

# Reserve for response (default: 2000)
# FOCUSA_RESERVE_FOR_RESPONSE=2000

# ECS externalize threshold (bytes, default: 8192)
# FOCUSA_ECS_THRESHOLD_BYTES=8192

# Focus Gate surface threshold (default: 2.2)
# FOCUSA_GATE_SURFACE_THRESHOLD=2.2
